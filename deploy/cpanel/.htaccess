# -----------------------------------------------------------------------------
# Planet Python — Apache rules for the cPanel docroot.
# Copy this file as `.htaccess` into the directory you set as `output_dir`
# (typically ~/public_html/). It is OPTIONAL: the site is plain static HTML
# and works fine without any rewrite rules.
# -----------------------------------------------------------------------------

# Serve index.html as the directory index.
DirectoryIndex index.html

# Long-cache the static assets so feed updates do not invalidate them.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css           "access plus 7 days"
    ExpiresByType image/gif          "access plus 30 days"
    ExpiresByType image/png          "access plus 30 days"
    ExpiresByType image/jpeg         "access plus 30 days"
    ExpiresByType image/svg+xml      "access plus 30 days"
    # Fonts never change once shipped — cache for a year.
    ExpiresByType font/woff2         "access plus 1 year"
    ExpiresByType font/woff          "access plus 1 year"
    ExpiresByType application/font-woff2  "access plus 1 year"
    # The HTML/RSS/Atom output is regenerated on every cron run; let browsers
    # revalidate after a few minutes.
    ExpiresByType text/html          "access plus 5 minutes"
    ExpiresByType application/rss+xml  "access plus 5 minutes"
    ExpiresByType application/atom+xml "access plus 5 minutes"
</IfModule>

# Mark fonts as immutable so browsers don't even revalidate within max-age.
<IfModule mod_headers.c>
    <FilesMatch "\.(woff2?|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Gzip compression for the text payloads.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/xml application/xml application/rss+xml application/atom+xml application/json application/javascript image/svg+xml
</IfModule>

# Make sure feeds and fonts are served with the correct content types.
AddType application/rss+xml          .rss .xml
AddType application/atom+xml         .atom
AddType font/woff2                   .woff2
AddType font/woff                    .woff
AddType application/manifest+json    .webmanifest

# Force HTTPS (cPanel + AutoSSL gives you a free certificate).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ======================== Security Headers ========================
<IfModule mod_headers.c>
    # Prevent clickjacking — only allow framing from same origin.
    Header always set X-Frame-Options "SAMEORIGIN"

    # Stop browsers from MIME-sniffing the content-type.
    Header always set X-Content-Type-Options "nosniff"

    # Modern guidance is to disable the legacy XSS auditor (it introduced
    # XS-leak vectors in old IE/Edge). Use CSP for real protection.
    Header always set X-XSS-Protection "0"

    # Control how much referrer info is leaked to external sites.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — tell browsers to always use HTTPS for 1 year (include subdomains).
    # NOTE: `preload` is intentionally omitted. Add it only after submitting
    # the domain at https://hstspreload.org/ and verifying every subdomain
    # serves HTTPS — preload-list removal takes weeks-to-months.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy — tight allow-list for a static aggregator.
    # - script-src 'self': no inline scripts, no eval.
    # - style-src 'self': sanitizer strips inline `style=` and templates use
    #   class selectors only, so 'unsafe-inline' is not needed.
    # - img-src allows external HTTPS hosts because feed entries link to
    #   images on the original blog hosts.
    # NOTE: <script type="application/ld+json"> blocks (used for Schema.org
    # SEO data) are NOT subject to script-src per CSP spec — the type is
    # non-executable, so browsers permit them with no extra CSP rule.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; font-src 'self'; img-src 'self' https: data:; frame-ancestors 'self';"

    # Permissions Policy — disable features we don't need.
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>
