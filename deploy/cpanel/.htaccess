# -----------------------------------------------------------------------------
# Planet Python — Apache rules for the cPanel docroot.
# Copy this file as `.htaccess` into the directory you set as `output_dir`
# (typically ~/public_html/). It is OPTIONAL: the site is plain static HTML
# and works fine without any rewrite rules.
# -----------------------------------------------------------------------------

# Serve index.html as the directory index.
DirectoryIndex index.html

# Long-cache the static assets so feed updates do not invalidate them.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css           "access plus 7 days"
    ExpiresByType image/gif          "access plus 30 days"
    ExpiresByType image/png          "access plus 30 days"
    ExpiresByType image/jpeg         "access plus 30 days"
    # The HTML/RSS/Atom output is regenerated on every cron run; let browsers
    # revalidate after a few minutes.
    ExpiresByType text/html          "access plus 5 minutes"
    ExpiresByType application/rss+xml  "access plus 5 minutes"
    ExpiresByType application/atom+xml "access plus 5 minutes"
</IfModule>

# Gzip compression for the text payloads.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/xml application/xml application/rss+xml application/atom+xml application/json
</IfModule>

# Make sure feeds are served with the correct content types.
AddType application/rss+xml   .rss .xml
AddType application/atom+xml  .atom

# Force HTTPS (cPanel + AutoSSL gives you a free certificate).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ======================== Security Headers ========================
<IfModule mod_headers.c>
    # Prevent clickjacking — only allow framing from same origin.
    Header always set X-Frame-Options "SAMEORIGIN"

    # Stop browsers from MIME-sniffing the content-type.
    Header always set X-Content-Type-Options "nosniff"

    # Enable strict XSS filter in older browsers.
    Header always set X-XSS-Protection "1; mode=block"

    # Control how much referrer info is leaked to external sites.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — tell browsers to always use HTTPS for 1 year (include subdomains).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy — allow self + inline styles (needed for planet output).
    # Fonts are now self-hosted, no external font/style sources needed.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' https: data:; frame-ancestors 'self';"

    # Permissions Policy — disable features we don't need.
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>
