<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#1e3a8a" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />
  <title><TMPL_VAR name></title>

  <!-- Preload the most-used Arabic font so first paint doesn't wait on CSS parsing. -->
  <link rel="preload" href="/fonts/tajawal-400-arabic.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cairo-arabic.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Stylesheet — preloaded so the browser starts fetching it earlier. -->
  <link rel="preload" href="/styles/rtl-arabic.css" as="style" />
  <link rel="stylesheet" href="/styles/rtl-arabic.css" />

  <!-- Favicon (reuses the existing SVG logo). -->
  <link rel="icon" type="image/svg+xml" href="/images/python-logo.svg" />
  <link rel="apple-touch-icon" href="/images/python-logo.svg" />

  <meta name="generator" content="<TMPL_VAR generator>" />
  <meta name="keywords" content="بايثون, مدونات, Python, planet, RSS, تجميع, خلاصات" />
  <meta name="description" content="آخر التدوينات من مدونات مجتمع بايثون — كوكب بايثون العربي." />

  <!-- Open Graph / Twitter Card for richer previews on social media. -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<TMPL_VAR name>" />
  <meta property="og:description" content="آخر التدوينات من مدونات مجتمع بايثون — كوكب بايثون العربي." />
  <meta property="og:image" content="/images/python-logo.svg" />
  <meta property="og:locale" content="ar_AR" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<TMPL_VAR name>" />
  <meta name="twitter:description" content="آخر التدوينات من مدونات مجتمع بايثون." />
  <meta name="twitter:image" content="/images/python-logo.svg" />

  <link rel="alternate" type="application/rss+xml" title="RSS" href="rss20.xml" />
  <link rel="alternate" type="application/atom+xml" title="Atom" href="atom.xml" />
</head>

<body id="top">
  <!-- Reading-progress bar at the very top of the viewport. -->
  <div id="reading-progress" aria-hidden="true"></div>

  <!-- شعار الموقع -->
  <h1 id="logoheader">
    <a href="/" id="logolink" accesskey="1"><img id="logo" src="/images/python-logo.svg" alt="كوكب بايثون" width="44" height="44" /></a>
  </h1>

  <div id="content-body">
    <div id="body-main">

<h1 class="pageheading"><TMPL_VAR name></h1>

<p>آخر تحديث: <TMPL_VAR date></p>

<TMPL_LOOP Items>

<TMPL_IF new_date>
<h2><TMPL_VAR new_date></h2>
</TMPL_IF>

<TMPL_IF new_channel>
<hr /><h3 class="post"><a href="<TMPL_VAR channel_link ESCAPE="HTML">" title="<TMPL_VAR channel_title ESCAPE="HTML">"><TMPL_VAR channel_name></a></h3>
</TMPL_IF>


<TMPL_IF title>
<h4><a href="<TMPL_VAR link ESCAPE="HTML">"><TMPL_VAR title></a></h4>
</TMPL_IF>
<p>
<TMPL_VAR content>
</p>
<p>
<em><a href="<TMPL_VAR link ESCAPE="HTML">"><TMPL_IF creator>بقلم <TMPL_VAR creator> — </TMPL_IF><TMPL_VAR date></a></em>
</p>
</TMPL_LOOP>

    </div>

    <aside id="left-hand-navigation">
    <div id="menu">
      <ul class="level-one">
          <li>
          <ul class="level-two">
             <li><a href="rss20.xml">📡 خلاصة RSS</a></li>
             <li><a href="atom.xml">📡 خلاصة Atom</a></li>
             <li><a href="titles_only.html">📃 العناوين فقط</a></li>
             <li><a href="summary.html">📝 ملخصات</a></li>
          </ul></li>

          <li>كواكب بايثون
            <ul class="level-two">
              <li><a href="https://planetpython.org/">Planet Python (الإنجليزية)</a></li>
              <li><a href="http://www.afpy.org/planet/">Planet Python (الفرنسية)</a></li>
              <li><a href="http://planeta.python.org.ar/">Planet Python (الأرجنتين)</a></li>
              <li><a href="http://planet.python.org.br/">Planet Python (البرازيل)</a></li>
            </ul></li>

          <li>مكتبات بايثون
          <ul class="level-two">
            <li><a href="http://planet.scipy.org/">SciPy</a></li>
            <li><a href="http://planet.sympy.org/">SymPy</a></li>
            <li><a href="http://planet.twistedmatrix.com/">Twisted</a></li>
          </ul></li>

          <li>كواكب الويب
          <ul class="level-two">
            <li><a href="https://www.djangoproject.com/community/">Django Community</a></li>
            <li><a href="http://planet.plone.org/">Plone</a></li>
          </ul></li>

          <li>المدونات المُشترَك بها
          <ul class="level-two">
<li><a href="opml.xml">📋 ملف OPML</a></li>
<TMPL_LOOP Channels>
<li><a href="<TMPL_VAR link ESCAPE="HTML">" title="<TMPL_VAR title ESCAPE="HTML">"><TMPL_VAR name></a></li>
</TMPL_LOOP>

<li>
    <em>
    لطلب إضافة أو إزالة مدوّنة،
    <a href="https://github.com/kader14/planet">افتح طلباً على GitHub</a>
    </em>
</li>
          </ul></li>
      </ul>
    </div>
    </aside>
  </div>

  <!-- Floating "back to top" button — pure-CSS visibility via :target+scroll. -->
  <a href="#top" id="back-to-top" aria-label="العودة لأعلى" title="العودة لأعلى">↑</a>

  <!-- Footer -->
  <footer id="site-footer">
    <div class="footer-inner">
      <p>
        كوكب بايثون العربي · مولّد بـ
        <a href="https://github.com/kader14/planet" rel="noopener">Planet</a>
      </p>
      <p class="footer-links">
        <a href="rss20.xml" rel="alternate">RSS</a>
        ·
        <a href="atom.xml" rel="alternate">Atom</a>
        ·
        <a href="opml.xml">OPML</a>
        ·
        <a href="https://github.com/kader14/planet" rel="noopener">GitHub</a>
      </p>
    </div>
  </footer>

  <!-- Tiny external script: reading-progress bar + back-to-top visibility.
       Loaded with `defer` so it doesn't block parsing. -->
  <script src="/scripts/site.js" defer></script>
</body>
</html>
